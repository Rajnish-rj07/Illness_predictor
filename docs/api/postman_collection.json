    },
    {
      "name": "Examples",
      "item": [
        {
          "name": "Complete Conversation Flow",
          "item": [
            {
              "name": "1. Create Session",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
